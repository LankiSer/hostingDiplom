SERVICE_NAME=deploy-service
SERVICE_PORT=8004
SERVICE_ENV=local
POSTGRES_URL=postgresql://platform:platform@postgres:5432/platform
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=platform.local
LOG_LEVEL=INFO
REGISTRY_ENDPOINT=http://registry:5000
RETRY_BASE_DELAY_MS=250
RETRY_MAX_ATTEMPTS=3
STORAGE_PROVIDER=filesystem
STORAGE_ROOT=/platform/storage
