SERVICE_NAME=gateway-service
ONEC_URL=
ONEC_USER=Администратор
ONEC_PASS=
SERVICE_PORT=8000
SERVICE_ENV=local
POSTGRES_URL=postgresql://platform:platform@postgres:5432/platform
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=platform.local
LOG_LEVEL=INFO
RETRY_BASE_DELAY_MS=250
RETRY_MAX_ATTEMPTS=3

# LiveKit configuration
LIVEKIT_URL=http://livekit:7880
LIVEKIT_PUBLIC_URL=wss://app.kostricyn.ru/livekit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
LIVEKIT_TURN_URL=
LIVEKIT_TURN_USERNAME=
LIVEKIT_TURN_PASSWORD=

# Tldraw configuration
TLDRAW_BASE_URL=
